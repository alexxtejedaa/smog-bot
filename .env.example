# SMOG Bot — Environment Variables Template
# Copy to .env and fill in actual values

# Authentication
AUTH_TOKEN=

# MEXC API
MEXC_API_KEY=
MEXC_API_SECRET=

# Trading Configuration
ACCOUNT_RISK=15
MAX_ACTIVE_POSITIONS=1
DEFAULT_LEVERAGE=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/smog-bot/webhook.log

# Server
HOST=0.0.0.0
PORT=8000

# Redis (optional, for caching)
REDIS_URL=

# Alerts Configuration
TOKENS=ETH,SOL,LINK,SUI,TAO
SIGNAL_TYPES=OG,FVG,ChoCh,ADX
